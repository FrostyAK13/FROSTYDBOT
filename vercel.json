{
  "rewrites": [
    {
      "source": "/((?!api|_next/static|_next/image|favicon.ico|manifest.json|sw.js|assets|js).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
